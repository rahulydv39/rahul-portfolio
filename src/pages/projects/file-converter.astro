---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="File Converter | Rahul">
    <section class="min-h-screen pt-40 px-8 md:px-24">
        <a
            href="/"
            class="text-gray-500 hover:text-white transition-colors uppercase tracking-[0.2em] text-sm mb-16 inline-block"
        >
            ← Back to Home
        </a>

        <h1
            class="text-6xl md:text-8xl font-bold text-white mb-6 tracking-tighter"
        >
            File Converter.
        </h1>

        <p class="text-xl text-gray-400 font-light max-w-2xl leading-relaxed">
            A fully optimized mobile application built to seamlessly handle
            format conversions on the go.
        </p>
    </section>
</Layout>
