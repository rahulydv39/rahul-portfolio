---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="zBrain AI Agent | Rahul">
    <section class="min-h-screen pt-40 px-8 md:px-24">
        <a
            href="/"
            class="text-gray-500 hover:text-white transition-colors uppercase tracking-[0.2em] text-sm mb-16 inline-block"
        >
            ← Back to Home
        </a>

        <h1
            class="text-6xl md:text-8xl font-bold text-white mb-6 tracking-tighter"
        >
            zBrain AI Agent.
        </h1>

        <div
            class="flex flex-col md:flex-row gap-12 mt-12 border-t border-gray-800 pt-12"
        >
            <div class="md:w-1/3">
                <h3
                    class="text-sm uppercase tracking-widest text-gray-500 mb-2"
                >
                    Achievement
                </h3>
                <p class="text-xl text-white">3rd Rank</p>
                <p class="text-gray-400">IIT Jodhpur Competition</p>
            </div>
            <div class="md:w-2/3">
                <h3
                    class="text-sm uppercase tracking-widest text-gray-500 mb-2"
                >
                    Project Overview
                </h3>
                <p class="text-xl text-gray-400 font-light leading-relaxed">
                    A comprehensive AI agent designed to autonomously execute
                    complex tasks. This project required deep integration of
                    machine learning models and efficient routing logic to
                    outperform competing agents in the live competition
                    environment.
                </p>
            </div>
        </div>
    </section>
</Layout>
